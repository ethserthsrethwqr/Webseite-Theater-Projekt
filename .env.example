# GMX SMTP credentials for ticket emails.
# Copy this file to .env and fill in the real values locally.
GMX_EMAIL=
GMX_PASSWORD=

# Local ports.
PUBLIC_PORT=3100
ADMIN_PORT=3101
VITE_HMR_PORT=24780

# Public domain used in cancellation links inside ticket emails.
PUBLIC_DOMAIN=theaterprojektklasse8.store
