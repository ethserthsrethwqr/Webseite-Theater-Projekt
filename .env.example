# GMX SMTP credentials for ticket emails.
# Copy this file to .env and fill in the real values locally.
GMX_EMAIL=
GMX_PASSWORD=

# Local ports.
PUBLIC_PORT=3100
ADMIN_PORT=3101
VITE_HMR_PORT=24780

# Public URL used in cancellation links inside ticket emails.
# For a local LAN deployment, use something like http://192.168.178.22.
PUBLIC_BASE_URL=

# Legacy fallback when PUBLIC_BASE_URL is empty.
PUBLIC_DOMAIN=theaterprojektklasse8.store

# Optional initial owner for a fresh database.
# If INITIAL_OWNER_PASSWORD is empty, the server generates and prints a one-time password.
INITIAL_OWNER_USERNAME=owner
INITIAL_OWNER_PASSWORD=

# Set to 1 only when running behind a trusted reverse proxy.
TRUST_PROXY=0
